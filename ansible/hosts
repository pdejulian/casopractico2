# =============================================================================
# hosts - Inventario de Ansible
# =============================================================================
# Sustituir <IP_PUBLICA_VM> por el valor real que devuelve:
#   terraform output -raw ip_publica_vm

[podman_vm]
vm-web ansible_host=<IP_PUBLICA_VM>

[podman_vm:vars]
ansible_user=azureuser
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_python_interpreter=/usr/bin/python3
